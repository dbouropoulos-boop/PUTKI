{
  "theme": "LIGHT",
  "archetype": "Swiss & High-Contrast (Editorial/Publication)",
  "color_palette": {
    "background": "#FBFAF8",
    "body_ink": "#0A0A0A",
    "brand_blue": "#1B2D5B",
    "subtle_border": "#E8E5DF",
    "muted_text": "#6B6862",
    "dial_states": {
      "KYLMÄ": "#2C5F8D",
      "HAALEA": "#7A7E83",
      "KUUMA": "#E8924A",
      "MYRSKY": "#C8423C",
      "KIIRASTULI": "#8B1E1A"
    }
  },
  "typography": {
    "fonts": {
      "display": "Inter, sans-serif",
      "reading": "'Source Serif 4', serif",
      "fallback": "Söhne, Tiempos, sans-serif"
    },
    "micro_typography": {
      "h1": {
        "mobile": "text-4xl",
        "desktop": "md:text-6xl",
        "classes": "font-bold tracking-tight text-[#0A0A0A] font-sans"
      },
      "h2": {
        "mobile": "text-2xl",
        "desktop": "md:text-4xl",
        "classes": "font-bold tracking-tight text-[#0A0A0A] font-sans"
      },
      "h3": {
        "mobile": "text-xl",
        "desktop": "md:text-2xl",
        "classes": "font-semibold tracking-tight text-[#0A0A0A] font-sans"
      },
      "body": {
        "mobile": "text-base",
        "desktop": "md:text-lg",
        "classes": "leading-relaxed text-[#0A0A0A] font-serif"
      },
      "eyebrow": {
        "classes": "uppercase tracking-widest text-xs font-bold text-[#6B6862] font-sans"
      },
      "numbers": {
        "classes": "tabular-nums"
      }
    }
  },
  "layout_and_spacing": {
    "grid_system": "12-column responsive grid",
    "container_max_width": "max-w-7xl",
    "padding": {
      "mobile": "px-4",
      "desktop": "md:px-8"
    },
    "section_gap": {
      "mobile": "py-12",
      "desktop": "md:py-24"
    },
    "border_radius": "4px",
    "shadows": "None (No gradients, no glows, no heavy shadows. Flat and editorial)"
  },
  "icons": {
    "library": "lucide-react",
    "stroke_width": "1.5px",
    "style": "clean, line-based, monochrome unless semantic"
  },
  "motion": {
    "dial_transitions": "600ms cubic-bezier(0.4, 0, 0.2, 1)",
    "live_pulse": "1.5s ease-in-out infinite",
    "score_count_up": "300ms ease-out"
  },
  "components": {
    "perkele_mittari_dial": {
      "description": "Animated SVG half-circle dial (180 degrees).",
      "sizes": {
        "hero": "480px",
        "cards": "280px",
        "inline": "64px"
      },
      "visual_rendering": {
        "proportions": "Half-circle (180 deg).",
        "tick_marks": "5 distinct segments matching dial states. Segments separated by minimal whitespace (1-2px gap).",
        "needle": "Base width 4px tapering to 1px tip. Anchored at bottom center. Color: #0A0A0A.",
        "labels": "Placed at tick marks along outer edge, font: Inter, text-xs, uppercase, tracking-widest.",
        "animation": "Needle rotates based on score (0-100 mapped to 0-180deg) with 600ms cubic-bezier."
      }
    },
    "trust_score_visualisations": {
      "description": "Score representations on operator pages.",
      "style": "Editorial, no gambling-affiliate cliches.",
      "radial": "Thin stroke circle (stroke-width: 2px), empty track is #E8E5DF, filled track uses dial state color. Score centered in Inter bold.",
      "horizontal_bar": "4px height, background #E8E5DF, fill uses dial state color. Square or 4px rounded edges."
    },
    "buttons": {
      "style": "Rectangular, 4px radius, #1B2D5B background, #FBFAF8 text, hover to slightly lighter blue, NO gradients, NO shadows."
    }
  },
